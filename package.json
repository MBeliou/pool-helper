{
	"name": "pool-helper",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:generate": "drizzle-kit generate",
		"db:copy-wasm": "copyfiles -f node_modules/sql.js/dist/sql-wasm.wasm static/assets",
		"cap:dev": "CAP_LIVE_RELOAD=http://$(ipconfig getifaddr en0):5001 cap sync ios",
		"cap:prod": "pnpm build && cap sync ios"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.4.0",
		"@eslint/js": "latest",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/manrope": "^5.2.8",
		"@fontsource-variable/space-grotesk": "^5.2.10",
		"@inlang/paraglide-js": "^2.18.2",
		"@lucide/svelte": "^1.17.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "next",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"clsx": "^2.1.1",
		"copyfiles": "^2.4.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.3.0",
		"sql.js": "^1.11.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@capacitor-community/sqlite": "^8.1.0",
		"@capacitor/core": "^8.4.0",
		"@capacitor/ios": "^8.4.0",
		"drizzle-orm": "^0.45.2",
		"jeep-sqlite": "^2.8.0"
	}
}
