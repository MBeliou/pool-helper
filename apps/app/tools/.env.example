# App Store release tooling — secrets. Copy to `.env` (untracked) and fill in.
# Loaded by every task in deno.json via `--env-file=.env`.

# ── renderfast (marketing screenshot framing) ───────────────────────────────
# Dashboard → API keys. Used as `Authorization: Bearer <key>`.
RENDERFAST_API_KEY=

# ── App Store Connect API ───────────────────────────────────────────────────
# App Store Connect → Users and Access → Integrations → App Store Connect API.
# Generate a key with the "App Manager" (or "Admin") role, download the .p8 ONCE.
# Keep the .p8 file OUTSIDE the repo (e.g. ~/.appstoreconnect/AuthKey_XXXX.p8).
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_P8_PATH=

# The app's bundle id / Apple ID (numeric adamId from App Store Connect).
ASC_BUNDLE_ID=care.mypool.app
ASC_APP_ID=
